# =============================================================
# Nexus402 / Nexus402 — 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# =============================================================

# ── 数据库 ──────────────────────────────────────────────────
# PostgreSQL 连接字符串
DATABASE_URL="postgresql://nexus402:password@localhost:5432/nexus402_db"

# ── JWT 鉴权 ─────────────────────────────────────────────────
# 必须设置！使用 openssl rand -hex 64 生成强密钥
# 不设置此项，服务将拒绝启动
JWT_SECRET="replace-me-with-a-strong-64-char-hex-secret"

# ── Stripe 支付 ──────────────────────────────────────────────
# 从 https://dashboard.stripe.com/apikeys 获取
STRIPE_SECRET_KEY="sk_test_..."
# Webhook 签名密钥（在 Stripe Dashboard → Webhooks 中创建端点后获取）
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── 平台配置 ─────────────────────────────────────────────────
# 平台抽佣比例（0.15 = 15%）
PLATFORM_COMMISSION_RATE="0.15"
# 服务端口（默认 4021）
PORT="4021"
# 运行环境
NODE_ENV="production"

# ── 前端（dashboard/.env.local）────────────────────────────
# VITE_API_BASE_URL=https://your-api-domain.com
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
