{
  "name": "wrap402",
  "version": "0.1.0",
  "description": "Wrap any digital asset into an x402-payable API endpoint for AI Agents",
  "type": "module",
  "bin": {
    "wrap402": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "demo:publish": "tsx src/cli.ts publish ./examples/company-risk.json --price 0.10 --name company-risk",
    "demo:serve": "tsx src/cli.ts serve",
    "demo:client": "tsx examples/agent-client.ts"
  },
  "keywords": ["x402", "micropayment", "ai-agent", "data-monetization"],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "nanoid": "^5.0.7",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
