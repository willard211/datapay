// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  apiKey    String?  @unique
  webhookUrl String?
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets       Asset[]
  transactions Transaction[] // User's spending (as payer)
}

model Asset {
  id           String   @id @default(cuid())
  providerId   String   // user who owns this asset
  provider     User     @relation(fields: [providerId], references: [id])
  name         String
  description  String?
  source       String   // File path or URL
  sourceType   String   // json, csv, api, scraper
  price        Float
  currency     String   @default("CNY")
  tags         String   @default("[]") // JSON string of tags array
  totalQueries Int      @default(0)
  totalRevenue Float    @default(0)
  publishedAt  DateTime @default(now())

  queries      Transaction[]
}

model Transaction {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])
  payerId    String
  payer      User     @relation(fields: [payerId], references: [id])
  amount     Float
  currency   String   @default("CNY")
  timestamp  DateTime @default(now())
}
