# =============================================================
# DataPay Dashboard — 环境变量配置模板
# 复制此文件为 .env.local 并填入真实值
# =============================================================

# 后端 API 地址（本地开发 or 云端部署）
VITE_API_BASE_URL=http://localhost:4021

# Stripe 可发布密钥（以 pk_ 开头，前端安全可用）
# 从 https://dashboard.stripe.com/apikeys 获取
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
